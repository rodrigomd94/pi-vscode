{
  "name": "pi-vscode",
  "displayName": "Pi Coding Agent",
  "version": "0.0.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/pi0/pi-vscode"
  },
  "icon": "assets/icon.png",
  "description": "VS Code extension for pi coding agent",
  "categories": [
    "AI",
    "Chat"
  ],
  "license": "MIT",
  "publisher": "pi0",
  "type": "module",
  "main": "./dist/extension.cjs",
  "scripts": {
    "build": "rolldown -c rolldown.config.ts",
    "dev": "rolldown -c rolldown.config.ts -w",
    "package": "pnpm build && pnpx @vscode/vsce package --no-dependencies",
    "release": "node scripts/release.ts",
    "fmt": "oxlint . --fix && oxfmt .",
    "lint": "oxlint . && oxfmt --check .",
    "typecheck": "tsgo --noEmit --skipLibCheck",
    "test": "pnpm lint && pnpm typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@types/vscode": "^1.93.0",
    "@typescript/native-preview": "^7.0.0-dev.20260226.1",
    "@vscode/vsce": "^3.5.0",
    "ovsx": "^0.10.9",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "rolldown": "1.0.0-rc.6",
    "vitest": "^4.0.18"
  },
  "contributes": {
    "icons": {
      "pi-logo": {
        "description": "Pi logo icon",
        "default": {
          "fontPath": "assets/fonts/pi-icons.woff2",
          "fontCharacter": "\\F101"
        }
      }
    },
    "chatParticipants": [
      {
        "id": "pi-vscode.chat",
        "fullName": "Pi Coding Agent",
        "name": "pi",
        "description": "Chat with Pi coding agent",
        "isSticky": true
      }
    ],
    "commands": [
      {
        "command": "pi-vscode.open",
        "title": "Pi: Open",
        "icon": {
          "light": "assets/logo-light.svg",
          "dark": "assets/logo.svg"
        }
      },
      {
        "command": "pi-vscode.openWithFile",
        "title": "Pi: Open with File",
        "icon": {
          "light": "assets/logo-light.svg",
          "dark": "assets/logo.svg"
        }
      },
      {
        "command": "pi-vscode.sendSelection",
        "title": "Pi: Send Selection"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "pi-vscode.openWithFile",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Pi",
      "properties": {
        "pi-vscode.path": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the pi binary. Leave empty for auto-detection."
        }
      }
    },
    "keybindings": [
      {
        "command": "pi-vscode.open",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "engines": {
    "vscode": "^1.93.0"
  }
}
